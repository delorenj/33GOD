# === HOST SETTINGS ===
# The domain you will access these apps on
DOMAIN_GLITCHTIP=glitchtip.lan
DOMAIN_PLANE=plane.lan

# === NATIVE DB CONNECTIVITY ===
# Connectivity to big-chungus host services (Linux - use actual IP)
DB_HOST=192.168.1.12
REDIS_HOST=192.168.1.12

# === GLITCHTIP DATABASE ===
# Database created in INF-1
GT_DB_NAME=glitchtip
GT_DB_USER=glitchtip_user
GT_DB_PASS=<from database setup>
GT_SECRET_KEY=<generate: openssl rand -hex 32>

# === PLANE DATABASE ===
# Database created in INF-1
PLANE_DB_NAME=plane
PLANE_DB_USER=plane_user
PLANE_DB_PASS=<from database setup>
PLANE_SECRET_KEY=<generate: openssl rand -hex 32>

# === MINIO (S3-Compatible Storage) ===
# MinIO credentials for Plane file attachments
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=<generate: openssl rand -hex 32>

# === RABBITMQ (Message Broker for Plane) ===
# RabbitMQ is required for Plane's Celery worker and email invitations
RABBITMQ_USER=plane_mq
RABBITMQ_PASSWORD=<generate: openssl rand -hex 32>
RABBITMQ_VHOST=plane

# === EMAIL CONFIGURATION (Optional) ===
# For production, configure SMTP settings. For development, emails log to console.
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
