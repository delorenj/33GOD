# === HOST SETTINGS ===
# The domain you will access these apps on
DOMAIN_GLITCHTIP=glitchtip.delo.sh
DOMAIN_PLANE=plane.delo.sh

# === NATIVE DB CONNECTIVITY ===
# Connectivity to big-chungus host services (Linux - use actual IP)
DB_HOST=192.168.1.12
REDIS_HOST=192.168.1.12

# === GLITCHTIP DATABASE ===
# Database created in INF-1
GT_DB_NAME=glitchtip
GT_DB_USER=your_glitchtip_db_user_here
GT_DB_PASS=your_glitchtip_db_password_here
GT_SECRET_KEY=your_glitchtip_secret_key_here

# === PLANE DATABASE ===
# Database created in INF-1
PLANE_DB_NAME=plane
PLANE_DB_USER=your_plane_db_user_here
PLANE_DB_PASS=your_plane_db_password_here
PLANE_SECRET_KEY=your_plane_secret_key_here

# === MINIO (S3-Compatible Storage) ===
# MinIO credentials for Plane file attachments
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=your_minio_password_here

# === RABBITMQ (Message Broker for Plane) ===
# RabbitMQ is required for Plane's Celery worker
RABBITMQ_USER=your_rabbitmq_user_here
RABBITMQ_PASSWORD=your_rabbitmq_password_here
RABBITMQ_VHOST=plane