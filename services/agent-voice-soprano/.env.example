# RabbitMQ / Bloodbank
RABBIT_URL=amqp://delorenj:changeme@localhost:5673/
EXCHANGE_NAME=bloodbank.events.v1

# Consumer
VOICE_QUEUE_NAME=services.agent.voice_soprano
VOICE_ROUTING_KEY=agent.*.message.received
VOICE_MAX_CHARS=500
VOICE_PREFIX_EVENT_TYPE=false
VOICE_DRY_RUN=false

# Soprano runtime
SOPRANO_BIN=soprano
SOPRANO_MODE=stream
# IMPORTANT: values with spaces must be quoted because run.sh sources this file.
# CPU-safe default for hosts without CUDA/NVIDIA.
SOPRANO_EXTRA_ARGS="--device cpu"
# If GPU is available, use: SOPRANO_EXTRA_ARGS="--device cuda"
SOPRANO_TIMEOUT_SEC=45
SOPRANO_OUTPUT_DIR=/tmp/agent-voice-soprano
SOPRANO_WAV_PLAYER=

# Per-agent profiles YAML
VOICE_PROFILES_PATH=./voice-profiles.yaml
