{
  "$id": "agent/heartbeat.v1.json",
  "title": "Agent Heartbeat",
  "description": "Periodic agent health signal",
  "type": "object",
  "required": ["event_type", "event_id", "timestamp", "version", "source", "payload"],
  "properties": {
    "event_type": { "type": "string", "const": "agent.heartbeat" },
    "event_id": { "type": "string", "format": "uuid" },
    "timestamp": { "type": "string", "format": "date-time" },
    "version": { "type": "string", "default": "1.0.0" },
    "source": { "$ref": "../_common/source.v1.json" },
    "correlation_ids": { "type": "array", "items": { "type": "string" } },
    "payload": {
      "type": "object",
      "required": ["agent_id", "status"],
      "properties": {
        "agent_id": { "type": "string" },
        "status": { "type": "string", "enum": ["alive", "degraded", "dying"] },
        "uptime_seconds": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
