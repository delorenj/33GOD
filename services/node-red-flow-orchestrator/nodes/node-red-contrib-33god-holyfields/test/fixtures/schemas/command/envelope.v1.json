{
  "$id": "command/envelope.v1.json",
  "title": "Command Envelope",
  "description": "Generic command envelope for agent dispatch",
  "type": "object",
  "required": ["event_type", "event_id", "timestamp", "version", "source", "payload"],
  "properties": {
    "event_type": { "type": "string" },
    "event_id": { "type": "string", "format": "uuid" },
    "timestamp": { "type": "string", "format": "date-time" },
    "version": { "type": "string", "default": "1.0.0" },
    "source": { "$ref": "../_common/source.v1.json" },
    "correlation_ids": { "type": "array", "items": { "type": "string" } },
    "payload": {
      "type": "object",
      "required": ["target_agent", "action"],
      "properties": {
        "target_agent": { "type": "string" },
        "action": { "type": "string" },
        "command_id": { "type": "string", "format": "uuid" },
        "params": { "type": "object" }
      }
    }
  }
}
