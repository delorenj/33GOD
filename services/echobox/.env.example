# Echobox - Transcription Service
# Copy to .env and fill in values

# MinIO (S3-compatible object storage)
MINIO_ACCESS_KEY=delorenj
MINIO_SECRET_KEY=changeme
MINIO_ENDPOINT=https://s3.delo.sh
MINIO_BUCKET=transcription-staging

# Fireflies API
FIREFLIES_API_KEY=changeme
FIREFLIES_WEBHOOK_URL=https://nodered.delo.sh/webhooks/fireflies

# Echobox Ledger (sidecar API)
DATABASE_URL=postgresql://delorenj:changeme@192.168.1.12:5432/echobox
LEDGER_API=http://localhost:18697

# Transcript output
TRANSCRIPT_DIR=/home/delorenj/d/Transcripts

# Bloodbank
BLOODBANK_API=http://127.0.0.1:8682
RABBITMQ_URL=amqp://guest:guest@localhost:5673/
