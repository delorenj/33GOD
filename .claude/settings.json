{
  "env": {
    "BLOODBANK_ENABLED": "true",
    "BLOODBANK_DEBUG": "false",
    "BLOODBANK_URL": "http://localhost:8682"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "cat | timeout 2 .claude/hooks/bloodbank-publisher.sh tool-action 2>/dev/null || true",
            "timeout": 3000,
            "description": "Publish tool usage to Bloodbank (fail-silent)"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"event\":\"session-end\"}' | timeout 2 .claude/hooks/bloodbank-publisher.sh session-end user_stop 2>/dev/null || true",
            "timeout": 3000,
            "description": "Publish session end to Bloodbank (fail-silent)"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{}' | timeout 2 .claude/hooks/bloodbank-publisher.sh session-start 2>/dev/null || true",
            "timeout": 3000,
            "description": "Publish session start to Bloodbank (fail-silent)"
          }
        ]
      }
    ]
  },
  "includeCoAuthoredBy": false
}
