{
  "env": {
    "BLOODBANK_ENABLED": "true",
    "BLOODBANK_DEBUG": "false",
    "BLOODBANK_DAPR_URL": "http://localhost:3503",
    "BLOODBANK_PUBSUB": "bloodbank-v3-pubsub"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cat | .claude/hooks/bloodbank-publisher.sh prompt-submitted",
            "description": "Publish user prompt submission to Bloodbank v3 (agent.prompt.submitted)"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "cat | .claude/hooks/bloodbank-publisher.sh tool-request",
            "description": "Publish tool-invocation intent to Bloodbank v3 (agent.tool.requested)"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "cat | .claude/hooks/bloodbank-publisher.sh tool-action",
            "description": "Publish tool-invocation result to Bloodbank v3 (agent.tool.invoked)"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cat | .claude/hooks/bloodbank-publisher.sh subagent-stopped",
            "description": "Publish subagent completion to Bloodbank v3 (agent.subagent.completed)"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{}' | .claude/hooks/bloodbank-publisher.sh session-end user_stop",
            "description": "Publish session end event to Bloodbank v3 with full statistics"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{}' | .claude/hooks/bloodbank-publisher.sh session-start",
            "description": "Publish session start event to Bloodbank v3"
          }
        ]
      }
    ]
  },
  "includeCoAuthoredBy": false,
  "statusLine": {
    "type": "command",
    "command": ".claude/statusline-command.sh"
  }
}
